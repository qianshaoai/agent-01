# ── Supabase ──────────────────────────────────────────────────────────────────
# 在 https://supabase.com/dashboard 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 服务端专用，不暴露给前端

# ── JWT ────────────────────────────────────────────────────────────────────────
# 至少 32 位随机字符串，可用 openssl rand -base64 32 生成
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# ── 语音识别（豆包/火山 ASR，可选）────────────────────────────────────────────
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=

# ── Supabase Storage（文件上传）────────────────────────────────────────────────
# 使用 Supabase Storage，在 Dashboard 创建名为 "uploads" 的公开 bucket
SUPABASE_STORAGE_BUCKET=uploads

# ── 体验版智能体（4.28up）─────────────────────────────────────────────────────
# 业务方提供的 Coze Bot ID 和 API Token；缺失时该体验智能体会被禁用
TRIAL_AGENT_001_BOT_ID=
TRIAL_AGENT_001_API_TOKEN=
TRIAL_AGENT_002_BOT_ID=
TRIAL_AGENT_002_API_TOKEN=

# ── 历史摘要降本（5.7up · 阶段二）────────────────────────────────────────────
# 用便宜的国内模型（如智谱 glm-4-flash）把"老对话"压成摘要，减少主对话 token 消耗。
# 平台层独立配置，与 agent 自身 key 解耦。摘要器调用费用由平台承担，不计入用户额度。
# 三个变量同时缺失则禁用摘要器，聊天逻辑退化为"截断老历史"（与 5.7up 之前行为一致）。
SUMMARIZER_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
SUMMARIZER_API_KEY=
SUMMARIZER_MODEL=glm-4-flash
