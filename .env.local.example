# ── Supabase ──────────────────────────────────────────────────────────────────
# 在 https://supabase.com/dashboard 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 服务端专用，不暴露给前端

# ── JWT ────────────────────────────────────────────────────────────────────────
# 至少 32 位随机字符串，可用 openssl rand -base64 32 生成
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# ── 加密 Key（5.14up Fix 3 引入）──────────────────────────────────────────────
# 用于加密存储 agent / tenant / user_agent 的 API key。
# 必须是 base64 编码的 32 字节（256-bit）随机值。
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# - production：必须配置，否则进程启动直接抛错
# - development：未配置时自动 fallback 到 JWT_SECRET 派生（带 console.warn），仅供本地调试
#
# ⚠ 一旦在 production 配置并部署，此 key 不可删除（已用它加密的新密文将无法解）。
# ⚠ 与 JWT_SECRET 分离的目的：避免轮换 JWT_SECRET 时破坏所有加密字段。
ENCRYPTION_KEY=

# ── 语音识别（豆包/火山 ASR，可选）────────────────────────────────────────────
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=

# ── Supabase Storage（文件上传）────────────────────────────────────────────────
# 使用 Supabase Storage，在 Dashboard 创建名为 "uploads" 的公开 bucket
SUPABASE_STORAGE_BUCKET=uploads

# ── 体验版智能体（4.28up）─────────────────────────────────────────────────────
# 业务方提供的 Coze Bot ID 和 API Token；缺失时该体验智能体会被禁用
TRIAL_AGENT_001_BOT_ID=
TRIAL_AGENT_001_API_TOKEN=
TRIAL_AGENT_002_BOT_ID=
TRIAL_AGENT_002_API_TOKEN=
